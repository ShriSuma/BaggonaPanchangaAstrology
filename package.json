{
  "name": "baggona-panchanga-astrology",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run kill-ports && vite --host 127.0.0.1 --port 5173",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "i18n:sync": "node scripts/sync-i18n-from-en.mjs",
    "i18n:translate": "node scripts/translate-untranslated-locale.mjs",
    "kill-ports": "npx kill-port 5173 3000 8080 || true",
    "check": "npm run kill-ports && npm run test && echo \"\\n✅ Tests passed. Starting dev server...\\n\" && npm run dev"
  },
  "dependencies": {
    "astronomy-engine": "^2.1.19",
    "date-fns": "^4.1.0",
    "dexie": "^4.0.11",
    "html2canvas": "^1.4.1",
    "i18next": "^24.2.2",
    "i18next-browser-languagedetector": "^8.0.3",
    "jspdf": "^2.5.2",
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-datepicker": "^9.1.0",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.2.0",
    "suncalc": "^1.9.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/google.maps": "^3.64.0",
    "@types/leaflet": "^1.9.12",
    "@types/node": "^22.13.8",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/suncalc": "^1.9.2",
    "@vitejs/plugin-react-swc": "^3.8.0",
    "@vitest/coverage-v8": "^3.0.8",
    "autoprefixer": "^10.4.20",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^5.4.14",
    "vite-plugin-pwa": "^0.21.2",
    "vitest": "^3.0.8",
    "workbox-core": "^7.3.0",
    "workbox-precaching": "^7.3.0",
    "workbox-routing": "^7.3.0",
    "workbox-strategies": "^7.3.0"
  }
}
